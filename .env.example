# =============================================================================
# AGUACLAUDE2026 — Plantilla de variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore — los secretos reales NO se commitean.
# =============================================================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=sbp_xxx

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AGUACLAUDE2026

# ---------- Email (Resend) — fase posterior ----------
